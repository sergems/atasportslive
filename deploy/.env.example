# =============================================================================
# ATA Platform — Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit the real .env file to version control.
# =============================================================================

# Strong random password for PostgreSQL (min 32 chars recommended)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_to_a_strong_random_password

# Strong random secret for JWT signing (min 64 chars recommended)
# Generate with: openssl rand -base64 64
SESSION_SECRET=change_me_to_a_strong_random_session_secret
