# =============================================================================
# ATA Platform — Production Environment Variables
# Copy this file to .env in the project root and fill in real values.
# NEVER commit the real .env file to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Strong random password for PostgreSQL (min 32 chars)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_to_a_strong_random_password

# ── Application ───────────────────────────────────────────────────────────────
# Strong random secret for JWT signing (min 64 chars)
# Generate with: openssl rand -base64 64
SESSION_SECRET=change_me_to_a_strong_random_session_secret

# ── Weekly Backup Email Notification ─────────────────────────────────────────
# SMTP server used to send the weekly backup notification email.
# Gmail example: use an App Password (not your regular password).
#   → https://myaccount.google.com/apppasswords
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password

# Recipient of the weekly backup notification
NOTIFY_EMAIL=info@atasportslive.com
